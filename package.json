{
  "name": "cisco-yang",
  "version": "1.2.0",
  "description": "CLI and SDK for IOS-XE devices via RESTCONF",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sieteunoseis/cisco-yang.git"
  },
  "author": "sieteunoseis",
  "license": "MIT",
  "keywords": [
    "cisco",
    "yang",
    "restconf",
    "ios-xe",
    "voice",
    "cube",
    "dial-peer",
    "sip",
    "networking",
    "cli"
  ],
  "main": "dist/index.js",
  "module": "main.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "cisco-yang": "./bin/cisco-yang.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./main.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node ./test/tests.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^14.0.3",
    "cli-table3": "^0.6.5",
    "csv-stringify": "^6.7.0",
    "@toon-format/toon": "^2.1.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  }
}
